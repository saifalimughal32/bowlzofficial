{%- unless product.has_only_default_variant -%}
  {%- capture variants_json -%}
  [
    {%- for variant in product.variants -%}
      {
        "id": {{ variant.id }},
        "available": {{ variant.available | json }},
        "price": {{ variant.price }},
        "compare_at_price": {{ variant.compare_at_price | default: 0 }},
        "currency": {{ cart.currency.iso_code | json }},
        "options": {{ variant.options | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
  {%- endcapture -%}

  <div class="mb-6 space-y-5" data-variant-picker data-variants='{{ variants_json | strip_newlines }}'>
    {%- for option in product.options_with_values -%}
      <div data-option-group data-default="{{ option.selected_value | escape }}">
        <p class="form-label">
          {{ option.name }}
          <span class="ml-2 font-normal normal-case text-muted" data-selected-label>— {{ option.selected_value }}</span>
        </p>

        {%- if option.name == 'Color' -%}
          <div class="flex flex-wrap gap-2.5" style="display:flex;flex-wrap:wrap;gap:0.625rem;">
            {%- for value in option.values -%}
              {%- assign available = false -%}
              {%- for variant in product.variants -%}
                {%- if variant.options contains value and variant.available -%}
                  {%- assign available = true -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              <button
                type="button"
                class="color-swatch{% if option.selected_value == value %} is-selected{% endif %}"
                data-option-value
                data-value="{{ value | escape }}"
                title="{{ value | escape }}"
                aria-label="{{ value | escape }}"
                aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                {% unless available %}disabled{% endunless %}
                style="background-color: {{ value | handle | replace: '-', '' }};"
              ></button>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="flex flex-wrap gap-2" style="display:flex;flex-wrap:wrap;gap:0.5rem;">
            {%- for value in option.values -%}
              {%- assign available = false -%}
              {%- for variant in product.variants -%}
                {%- if variant.options contains value and variant.available -%}
                  {%- assign available = true -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              <button
                type="button"
                class="variant-pill{% if option.selected_value == value %} is-selected{% endif %}"
                data-option-value
                data-value="{{ value | escape }}"
                {% unless available %}disabled{% endunless %}
              >
                {{ value }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
{%- endunless -%}
