<a href="{{ routes.root_url }}" class="logo-link{% if variant == 'light' %} logo-link--light{% endif %}" data-logo aria-label="{{ shop.name }} home">
  {%- if settings.logo != blank -%}
    {{ settings.logo | image_url: width: 483 | image_tag: alt: shop.name, loading: 'eager', widths: '120,180,240,483' }}
  {%- else -%}
    <img src="{{ 'bowlz-logo.png' | asset_url }}" alt="{{ shop.name }}" width="483" height="138" loading="eager">
  {%- endif -%}
</a>
