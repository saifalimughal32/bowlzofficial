{%- liquid
  assign threshold = settings.free_shipping_threshold | times: 100
  assign subtotal = cart.total_price
  assign remaining = threshold | minus: subtotal
  assign progress = subtotal | times: 100 | divided_by: threshold
  if progress > 100
    assign progress = 100
  endif
-%}

<div id="cart-drawer-overlay" class="cart-drawer-overlay" aria-hidden="true">
  <div class="cart-drawer-overlay__backdrop" data-cart-backdrop></div>
  <div id="cart-drawer" class="cart-drawer" role="dialog" aria-label="{{ 'cart.general.title' | t }}">
    <div class="mb-4 flex items-center justify-between">
      <h3 class="text-xl font-bold text-charcoal">{{ 'cart.general.title' | t }}</h3>
      <button type="button" data-cart-close class="text-2xl text-charcoal" aria-label="Close cart" style="background:none;border:none;cursor:pointer;font-size:1.5rem;">×</button>
    </div>

    {%- if cart.item_count == 0 -%}
      <p class="py-8 text-center text-muted">{{ 'cart.general.empty' | t }}</p>
    {%- else -%}
      {%- if remaining <= 0 -%}
        <div class="mb-4 rounded-xl px-4 py-3 text-center text-sm font-medium text-charcoal" style="background:rgba(0,0,0,0.03);border-radius:0.75rem;">
          🎉 {{ 'cart.general.free_shipping_unlocked' | t }}
        </div>
      {%- else -%}
        <div class="mb-4 rounded-xl px-4 py-3" style="background:rgba(0,0,0,0.03);border-radius:0.75rem;">
          <p class="mb-2 text-center text-sm text-muted">
            Add <span class="font-semibold text-charcoal">{{ remaining | money }}</span> for free shipping
          </p>
          <div class="shipping-progress">
            <div class="shipping-progress-fill" style="width: {{ progress }}%;"></div>
          </div>
        </div>
      {%- endif -%}

      <div class="flex-1 overflow-y-auto" style="flex:1;overflow-y:auto;">
        {%- for item in cart.items -%}
          <div class="flex gap-4 border-b py-4" style="display:flex;gap:1rem;border-bottom:1px solid rgba(0,0,0,0.08);padding:1rem 0;">
            <div class="relative h-20 w-20 shrink-0 overflow-hidden rounded-lg bg-white" style="width:5rem;height:5rem;flex-shrink:0;border-radius:0.5rem;overflow:hidden;">
              {%- if item.image -%}
                {{ item.image | image_url: width: 160 | image_tag: alt: item.product.title, loading: 'lazy' }}
              {%- endif -%}
            </div>
            <div class="flex-1" style="flex:1;">
              <p class="text-sm font-semibold">{{ item.product.title }}</p>
              <p class="text-sm text-muted">{{ item.variant.title }}</p>
              <p class="mt-1 font-bold">{{ item.final_line_price | money }}</p>
              <div class="mt-2 flex items-center gap-3" style="display:flex;align-items:center;gap:0.75rem;margin-top:0.5rem;">
                <div class="flex items-center rounded-full border" style="display:flex;border-radius:9999px;border:1px solid rgba(27,37,47,0.15);">
                  <button type="button" data-cart-qty-change data-line-key="{{ item.key }}" data-qty="{{ item.quantity | minus: 1 }}" class="px-2.5 py-1 text-sm" style="background:none;border:none;cursor:pointer;" aria-label="Decrease quantity">−</button>
                  <span class="px-2 text-sm font-medium">{{ item.quantity }}</span>
                  <button type="button" data-cart-qty-change data-line-key="{{ item.key }}" data-qty="{{ item.quantity | plus: 1 }}" class="px-2.5 py-1 text-sm" style="background:none;border:none;cursor:pointer;" aria-label="Increase quantity">+</button>
                </div>
                <button type="button" data-cart-remove data-line-key="{{ item.key }}" class="text-xs underline" style="background:none;border:none;cursor:pointer;font-size:0.75rem;">{{ 'cart.general.remove' | t }}</button>
              </div>
            </div>
          </div>
        {%- endfor -%}

        {%- if settings.cart_upsell_product != blank and cart.item_count == 1 -%}
          {%- assign upsell = all_products[settings.cart_upsell_product] -%}
          {%- if upsell.available -%}
            <div class="mt-4 rounded-xl border border-dashed p-4" style="margin-top:1rem;border-radius:0.75rem;border:1px dashed rgba(0,0,0,0.2);padding:1rem;">
              <p class="text-sm font-semibold text-charcoal">{{ settings.cart_upsell_label }}</p>
              <p class="mt-1 text-xs text-muted">{{ settings.cart_upsell_description }}</p>
              <button type="button" data-cart-upsell data-variant-id="{{ upsell.selected_or_first_available_variant.id }}" class="mt-3 text-sm font-semibold underline" style="background:none;border:none;cursor:pointer;margin-top:0.75rem;color:var(--color-brand);">
                Add for {{ upsell.price | money }} →
              </button>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="mt-4 rounded-xl p-4 text-center text-sm text-muted" style="margin-top:1rem;background:rgba(0,0,0,0.03);border-radius:0.75rem;padding:1rem;">
      🔁 {{ 'cart.general.warranty_note' | t }}
    </div>

    <div class="mt-auto border-t pt-4" style="margin-top:auto;border-top:1px solid rgba(0,0,0,0.08);padding-top:1rem;">
      <div class="mb-4 flex justify-between text-lg font-bold" style="display:flex;justify-content:space-between;margin-bottom:1rem;">
        <span>{{ 'cart.general.subtotal' | t }}</span>
        <span>{{ cart.total_price | money }}</span>
      </div>
      <button type="button" data-cart-checkout class="btn-primary btn-full" {% if cart.item_count == 0 %}disabled{% endif %}>
        {{ 'cart.general.checkout' | t }}
      </button>
      {% render 'payment-icons' %}
      <p class="mt-3 text-center text-xs text-muted">
        Free USA shipping on orders over ${{ settings.free_shipping_threshold }}
      </p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
