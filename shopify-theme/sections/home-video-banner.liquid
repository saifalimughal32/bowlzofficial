<section class="relative flex min-h-svh w-full items-center justify-center overflow-hidden bg-black" style="position:relative;display:flex;min-height:100svh;width:100%;align-items:center;justify-content:center;overflow:hidden;background:#000;">
  {%- if section.settings.video != blank -%}
    {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'absolute inset-0 h-full w-full object-cover', style: 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;' }}
  {%- else -%}
    <video class="absolute inset-0 h-full w-full object-cover" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" autoplay muted loop playsinline preload="auto" aria-label="Bowlz brand video">
      <source src="{{ 'bongz-hero.mp4' | asset_url }}" type="video/mp4">
    </video>
  {%- endif -%}

  <div class="pointer-events-none absolute inset-0 bg-black/45" style="position:absolute;inset:0;background:rgba(0,0,0,0.45);"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-4 py-24 text-center sm:px-6 md:px-10 md:py-32" style="position:relative;z-index:10;text-align:center;padding:6rem 1rem;">
    <h1 class="hero-headline mb-8 text-white md:mb-10" style="color:#fff;margin-bottom:2rem;">
      {{ section.settings.headline_line1 }}
      <br class="hidden sm:block">
      <span class="sm:hidden"> </span>
      {{ section.settings.headline_line2 }}
    </h1>
    <a href="{{ section.settings.button_url | default: routes.all_products_collection_url }}" class="btn-pill btn-pill-white pointer-events-auto">
      {{ section.settings.button_label }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Video banner",
  "tag": "section",
  "class": "home-video-banner",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Hero video"
    },
    {
      "type": "text",
      "id": "headline_line1",
      "label": "Headline line 1",
      "default": "Magnetic Bowls Built for"
    },
    {
      "type": "text",
      "id": "headline_line2",
      "label": "Headline line 2",
      "default": "Your Session, Not Your Floor."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Bowlz"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [{ "name": "Video banner" }]
}
{% endschema %}
