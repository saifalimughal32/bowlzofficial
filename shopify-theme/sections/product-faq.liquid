<section class="section" id="faq">
  <div class="container-main">
    <h2 class="mb-8 text-center text-[clamp(1.75rem,4vw,2.5rem)]" style="text-align:center;margin-bottom:2rem;font-size:clamp(1.75rem,4vw,2.5rem);">
      {{ section.settings.heading }}
    </h2>
    <div class="mx-auto max-w-[720px]" style="max-width:720px;margin:0 auto;">
      {%- for block in section.blocks -%}
        <div class="border-b border-black/10" data-faq-item {{ block.shopify_attributes }} style="border-bottom:1px solid rgba(0,0,0,0.08);">
          <button
            type="button"
            class="flex w-full items-center justify-between py-5 text-left font-semibold text-charcoal"
            data-faq-toggle
            aria-expanded="false"
            style="display:flex;width:100%;justify-content:space-between;padding:1.25rem 0;text-align:left;font-weight:600;background:none;border:none;cursor:pointer;color:var(--color-charcoal);"
          >
            {{ block.settings.question }}
            <span class="ml-4 text-xl transition-transform duration-200" style="margin-left:1rem;font-size:1.25rem;">+</span>
          </button>
          <div data-faq-panel class="overflow-hidden transition-all duration-300" style="max-height:0;overflow:hidden;transition:max-height 0.3s;">
            <p class="text-[0.9375rem] leading-relaxed text-muted pb-5" style="line-height:1.625;color:var(--color-muted);padding-bottom:1.25rem;">{{ block.settings.answer }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Questions? We've got you."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "What size bong does Bowlz fit?", "answer": "All Bowlz magnetic bowl pieces are designed for standard 14mm bong joints. Check individual product pages for size details on XL and specialty models." } },
        { "type": "faq", "settings": { "question": "Is Bowlz really shatterproof?", "answer": "Yes — Bowlz is made from food-grade, cool-touch materials that won't shatter like traditional glass. It's built for real-life sessions." } },
        { "type": "faq", "settings": { "question": "How do I clean my Bowlz?", "answer": "Most Bowlz pieces clean with a single wipe post-session. Pair with Swabz for a deeper clean on your bong and downstem." } },
        { "type": "faq", "settings": { "question": "Do the magnets affect airflow?", "answer": "No — Bowlz uses an airtight magnetic seal designed to maintain full airflow through your piece without leaks or drag." } },
        { "type": "faq", "settings": { "question": "What's the current promotion?", "answer": "20% off magnetic glass plus a free OG bowl while supplies last. Discount applied automatically at checkout on eligible items." } },
        { "type": "faq", "settings": { "question": "Do you offer wholesale?", "answer": "Yes — we work with smoke shops and dispensaries nationwide. Visit our wholesale page or contact us to create a wholesale account." } }
      ]
    }
  ]
}
{% endschema %}
