<section id="wholesale" class="home-section" style="background:#fafafa;" data-wholesale-section>
  <div class="container-main">
    <div data-wholesale-options>
      <div class="mx-auto max-w-2xl text-center" style="max-width:42rem;margin:0 auto;text-align:center;">
        <h2 class="text-2xl font-bold tracking-tight text-ink md:text-3xl">{{ section.settings.heading }}</h2>
        <p class="mt-3 text-sm text-muted md:text-base">{{ section.settings.subtext }}</p>

        <div class="mt-10 grid gap-4 sm:grid-cols-2" style="margin-top:2.5rem;display:grid;gap:1rem;">
          <button type="button" data-wholesale-option class="group flex flex-col items-center rounded-2xl border border-black/[0.08] bg-white px-6 py-8 text-center shadow-[0_4px_20px_rgba(0,0,0,0.04)]" style="display:flex;flex-direction:column;align-items:center;border-radius:1rem;border:1px solid rgba(0,0,0,0.08);background:#fff;padding:2rem 1.5rem;cursor:pointer;">
            <span class="inline-flex min-h-[48px] items-center rounded-full bg-ink px-8 text-sm font-bold uppercase tracking-[0.06em] text-white">{{ section.settings.apply_label }}</span>
            <span class="mt-4 text-xs text-muted md:text-sm">{{ section.settings.apply_desc }}</span>
          </button>
          <button type="button" data-wholesale-option class="group flex flex-col items-center rounded-2xl border border-black/[0.08] bg-white px-6 py-8 text-center shadow-[0_4px_20px_rgba(0,0,0,0.04)]" style="display:flex;flex-direction:column;align-items:center;border-radius:1rem;border:1px solid rgba(0,0,0,0.08);background:#fff;padding:2rem 1.5rem;cursor:pointer;">
            <span class="inline-flex min-h-[48px] items-center rounded-full bg-ink px-8 text-sm font-bold uppercase tracking-[0.06em] text-white">{{ section.settings.account_label }}</span>
            <span class="mt-4 text-xs text-muted md:text-sm">{{ section.settings.account_desc }}</span>
          </button>
        </div>
      </div>
    </div>

    <div data-wholesale-form hidden class="wholesale-reveal mx-auto max-w-3xl" style="max-width:48rem;margin:0 auto;">
      <button type="button" data-wholesale-back class="mb-8 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.06em] text-muted" style="background:none;border:none;cursor:pointer;margin-bottom:2rem;">
        <span aria-hidden>←</span> {{ 'wholesale.back' | t }}
      </button>

      <div class="rounded-2xl border border-black/[0.06] bg-white px-6 py-10 shadow-[0_8px_30px_rgba(0,0,0,0.04)] md:px-10 md:py-12" style="border-radius:1rem;border:1px solid rgba(0,0,0,0.06);background:#fff;padding:2.5rem 1.5rem;">
        <div class="mb-8 text-center">
          <h2 class="text-2xl font-bold uppercase tracking-tight text-ink md:text-3xl">{{ 'wholesale.form_heading' | t }}</h2>
          <p class="mt-2 text-sm text-muted md:text-base">{{ 'wholesale.form_subtext' | t }}</p>
        </div>

        <form
          class="space-y-5"
          data-mailto-form
          data-mailto-email="{{ settings.contact_email }}"
          data-mailto-subject="Wholesale Contact Form"
          data-mailto-body-fn="bowlzWholesaleBody"
        >
          <div>
            <label for="wholesale-name-shop" class="form-label">Name/Shop<span class="text-red-600">*</span></label>
            <input id="wholesale-name-shop" name="nameShop" type="text" required class="form-input">
          </div>
          <div>
            <label for="wholesale-tax-id" class="form-label">Tax ID/EIN</label>
            <input id="wholesale-tax-id" name="taxId" type="text" class="form-input">
          </div>
          <div class="grid gap-5 sm:grid-cols-2" style="display:grid;gap:1.25rem;">
            <div>
              <label for="wholesale-email" class="form-label">Email<span class="text-red-600">*</span></label>
              <input id="wholesale-email" name="email" type="email" required class="form-input">
            </div>
            <div>
              <label for="wholesale-phone" class="form-label">Phone<span class="text-red-600">*</span></label>
              <input id="wholesale-phone" name="phone" type="tel" required class="form-input" placeholder="(555) 000-0000">
            </div>
          </div>
          <div>
            <label for="wholesale-country" class="form-label">Country</label>
            <select id="wholesale-country" name="country" class="form-input">
              <option value="United States">United States</option>
              <option value="Canada">Canada</option>
              <option value="United Kingdom">United Kingdom</option>
              <option value="Australia">Australia</option>
            </select>
          </div>
          <div>
            <label for="wholesale-address" class="form-label">Address</label>
            <input id="wholesale-address" name="address" type="text" class="form-input">
          </div>
          <div class="grid gap-5 sm:grid-cols-2" style="display:grid;gap:1.25rem;">
            <div>
              <label for="wholesale-city" class="form-label">City</label>
              <input id="wholesale-city" name="city" type="text" class="form-input">
            </div>
            <div>
              <label for="wholesale-postal" class="form-label">Postal code</label>
              <input id="wholesale-postal" name="postalCode" type="text" class="form-input">
            </div>
          </div>
          <div>
            <label for="wholesale-contact-method" class="form-label">Preferred Method of contact<span class="text-red-600">*</span></label>
            <select id="wholesale-contact-method" name="contactMethod" required class="form-input">
              <option value="">Select one</option>
              <option value="Email">Email</option>
              <option value="Phone">Phone</option>
              <option value="Text">Text</option>
            </select>
          </div>
          <div>
            <label for="wholesale-message" class="form-label">Message</label>
            <textarea id="wholesale-message" name="message" rows="6" class="form-input form-textarea"></textarea>
          </div>
          <button type="submit" class="btn-pill btn-pill-brand">{{ 'wholesale.submit' | t }}</button>
        </form>
        <p data-form-success hidden class="rounded-xl bg-brand/10 px-4 py-4 text-center text-sm font-medium text-brand" style="margin-top:1rem;">{{ 'wholesale.success' | t }}</p>
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 640px) {
    [data-wholesale-options] .grid { grid-template-columns: repeat(2, 1fr); }
    [data-wholesale-form] .grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

{% schema %}
{
  "name": "Wholesale CTA",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Got a Smokeshop or Dispensary?" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Choose an option below and our wholesale team will be in touch." },
    { "type": "text", "id": "apply_label", "label": "Apply button", "default": "Apply for Wholesale" },
    { "type": "text", "id": "apply_desc", "label": "Apply description", "default": "New smoke shops & dispensaries" },
    { "type": "text", "id": "account_label", "label": "Account button", "default": "Create Wholesale Account" },
    { "type": "text", "id": "account_desc", "label": "Account description", "default": "Get set up with our wholesale team" }
  ],
  "presets": [{ "name": "Wholesale CTA" }]
}
{% endschema %}
